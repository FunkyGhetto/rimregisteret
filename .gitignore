# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# Data (processed intermediates and raw source data)
data/processed/*.jsonl
data/processed/*.log
data/raw/
# DB: definisjoner.db og semantics.db trackes direkte.
# rimindeks.db er for stor (274 MB) — splittet i .part-filer og
# settes sammen ved build. Selve rimindeks.db ignoreres.
data/db/rimindeks.db
# SQLite temp/journal files and FUSE artifacts — never track
*.db-wal
*.db-shm
*.db-journal
data/db/.fuse_hidden*

